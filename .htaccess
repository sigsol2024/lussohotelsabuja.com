# Pretty URLs (no .php) for the public site — requires AllowOverride + mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Existing files and directories (assets, admin, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # /page → page.php when that file exists
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^([A-Za-z0-9_-]+)/?$ $1.php [L,QSA]
</IfModule>
